# Model settings
ANALYZER_MODEL=your_model_name
ANALYZER_TEMPERATURE=0.3
ANALYZER_MAX_TOKENS=1000
ANALYZER_TIMEOUT=30

# API settings
DOUBAO_API_URL=https://
DOUBAO_API_KEY=your_doubao_api_key
OPENAI_BASE_URL=https://
OPENAI_API_KEY=your_openai_api_key

# Git settings
GIT_REPO_URL=https://github.com/your-org/your-repo.git
GITHUB_TOKEN=your_github_token
GIT_BRANCH_PREFIX=fix-
GIT_COMMIT_MESSAGE=Auto-fix: {error_summary}
GIT_PR_TITLE=Auto-fix: {error_summary}
GIT_PR_BODY=This is an automated fix for the error: {error_summary}

# Feishu settings
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_WEBHOOK_URL=your_feishu_webhook_url
FEISHU_RETRY_COUNT=3
FEISHU_RETRY_INTERVAL=5

# Monitoring settings
LOG_PATH=./app.log
MONITOR_LOG_PATTERN=ERROR|Exception|Traceback
MONITOR_CHECK_INTERVAL=10
MONITOR_MAX_LOG_SIZE=1048576
HEALTHCHECK_URLS=[]
HEALTHCHECK_TIMEOUT=5

# Demo service defaults
DEFAULT_SERVICE_NAME=demo-web-service
DEFAULT_REPO_URL=https://github.com/your-org/demo-web-service-repo.git
DEFAULT_BRANCH=main
DEFAULT_REPAIR_BRANCH_PREFIX=autofix
DEFAULT_REPO_ROOT=E:\path\to\demo-web-service-repo
DEFAULT_RUNTIME_ROOT=E:\path\to\demo-web-service-runtime
DEFAULT_RUNTIME_LOG_PATH=E:\path\to\demo-web-service-runtime\logs\demo_service.log
DEFAULT_FEISHU_WEBHOOK_URL=

# Runtime settings
MAX_ITERATIONS=3
STAGE_ONE_DEDUP_TTL_SEC=3600
TOOL_TIMEOUT_SEC=60

# Audit settings
AUDIT_STORAGE_PATH=./audit
