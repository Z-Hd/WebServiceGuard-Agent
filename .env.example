# Model settings
ANALYZER_MODEL=ep-20260423222752-9tcpw
ANALYZER_TEMPERATURE=0.3
ANALYZER_MAX_TOKENS=1000
ANALYZER_TIMEOUT=30

# API settings
DOUBAO_API_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_API_KEY=your_doubao_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your_openai_api_key

# Git settings
GIT_REPO_URL=https://github.com/your/repo.git
GITHUB_TOKEN=your_github_token
GIT_BRANCH_PREFIX=fix-
GIT_COMMIT_MESSAGE=Auto-fix: {error_summary}
GIT_PR_TITLE=Auto-fix: {error_summary}
GIT_PR_BODY=This is an automated fix for the error: {error_summary}

# Feishu settings
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_WEBHOOK_URL=your_feishu_webhook_url
FEISHU_RETRY_COUNT=3
FEISHU_RETRY_INTERVAL=5

# Monitoring settings
LOG_PATH=./app.log
MONITOR_LOG_PATTERN=ERROR|Exception|Traceback
MONITOR_CHECK_INTERVAL=10
MONITOR_MAX_LOG_SIZE=1048576
HEALTHCHECK_URLS=[]
HEALTHCHECK_TIMEOUT=5

